# PACT-AX environment variables
# Copy to .env and edit — docker compose reads .env automatically.

# ── Server ────────────────────────────────────────────────────────────────────
# Port exposed on the host (container always listens on 8000)
PACT_PORT=8000

# ── Auth ──────────────────────────────────────────────────────────────────────
# Set to 1 in production to enforce API key authentication on every request.
# When 0 (default for local dev), all endpoints are open.
PACT_ENFORCE_AUTH=0

# ── SQLite DB paths ───────────────────────────────────────────────────────────
# Default paths write to the current working directory.
# In Docker these are overridden to /data (mounted volume) by docker-compose.yml.
PACT_ACCESS_DB=access.db
PACT_TRUST_DB=trust.db
PACT_CAP_DB=capabilities.db
PACT_STORY_DB=story_keeper.db
PACT_MEMORY_DB=episodic.db
PACT_DLQ_DB=dlq.db

# ── MCP client (pact_ax.mcp.server) ──────────────────────────────────────────
# URL the MCP server uses to reach the PACT-AX REST API.
PACT_AX_URL=http://localhost:8000
